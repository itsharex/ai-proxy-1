{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Proxy",
  "version": "0.4.17",
  "identifier": "com.aiproxy.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "AI Proxy",
        "width": 1360,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI5RkY2NEQyOURCNjY3MEEKUldRS1o3YWQwbVQvS1pkTnBxbHlrWk9rQXk5eEhNSXdDWHJnQjdyR0xzRThiTUZOTW9FbUJLV0MK",
      "endpoints": [
        "https://github.com/mrhuangyong/ai-proxy/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
