# === Required ===

# Master key for encrypting API keys in database.
# MUST be consistent across restarts, or encrypted data becomes unreadable.
MASTER_KEY=change-me-to-a-random-string

# JWT secret for token signing.
# MUST be consistent across restarts, or existing tokens become invalid.
JWT_SECRET=change-me-to-another-random-string

# === Optional ===

# Initial admin password (only used on first startup when no users exist).
# If omitted, a random password is generated and printed to stdout on first run.
ADMIN_PASSWORD=

# External port to expose (default: 7860)
PORT=7860

# Frontend static files directory (inside container). Leave empty to skip.
STATIC_DIR=

# Log level: trace, debug, info, warn, error (default: info)
LOG_LEVEL=info

AI_PROXY_DATA_DIR=/data
AI_PROXY_STATIC_DIR=/app/static